# Copy this file to .env.local for local development
# Add the same values to your deployment platform for production
# NEVER commit real secrets to version control

VITE_SUPABASE_URL=your_supabase_project_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
VITE_PUBLIC_APP_URL=https://hamakom.app

# Sentry error monitoring — get your DSN from sentry.io (free tier)
# Leave blank to disable error reporting
VITE_SENTRY_DSN=

# ── Scripts only (never used by the frontend) ─────────────────────────────
# Supabase service role key — Settings → API → service_role (keep secret)
SUPABASE_SERVICE_KEY=

# Google Places API key — used by scripts/populate-images.mjs only
# Enable "Places API (New)" at console.cloud.google.com
GOOGLE_PLACES_KEY=
